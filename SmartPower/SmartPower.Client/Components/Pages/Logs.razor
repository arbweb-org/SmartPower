@page "/logs"
@using SmartPower.Client.Services
@inject StorageService StorageService
@inject NavigationManager NavigationManager

<div class="logs-container">
    <div class="header" style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px; background: #f3f3f3; padding: 10px; border-radius: 8px;">
        <button class="btn btn-secondary" @onclick="GoBack">Back</button>
        <h3 style="margin: 0;">Saved Logs</h3>
    </div>

    <div class="logs-list" style="overflow-x: auto;">
        @if (_logs == null)
        {
            <p>Loading...</p>
        }
        else if (_logs.Count == 0)
        {
            <p>No logs found.</p>
        }
        else
        {
            <table class="table table-striped" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid #ccc; text-align: left;">
                        <th style="padding: 10px;">Date</th>
                        <th style="padding: 10px;">Type</th>
                        <th style="padding: 10px;">Size</th>
                        <th style="padding: 10px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in _logs)
                    {
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 10px;">@log.Created.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td style="padding: 10px;">@(log.IsReadings ? "Readings" : "RMS")</td>
                            <td style="padding: 10px;">@(log.Size / 1024) KB</td>
                            <td style="padding: 10px;">
                                <button class="btn btn-primary btn-sm" style="padding: 4px 8px; margin-right: 5px;" @onclick="() => ViewLog(log)">View</button>
                                <button class="btn btn-danger btn-sm" style="padding: 4px 8px;" @onclick="() => DeleteLog(log)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (_selectedLog != null)
    {
        <div class="log-viewer" style="margin-top: 30px; border-top: 2px solid #ddd; padding-top: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h4 style="margin: 0;">Viewing: @_selectedLog.Name</h4>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _selectedLog = null">Close</button>
            </div>
            <div class="chart-container" style="height: 300px; background: #fff; margin-top: 15px; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                <svg viewBox="0 0 5000 240" preserveAspectRatio="none" style="width:100%; height:100%; background-color:aliceblue;">
                     <line x1="0" y1="120" x2="5000" y2="120" stroke="silver" stroke-width="1" vector-effect="non-scaling-stroke" />
                     <polyline points="@_points" fill="none" stroke="@(_selectedLog.IsReadings ? "blue" : "red")" stroke-width="1.5" vector-effect="non-scaling-stroke" />
                </svg>
            </div>
            <div style="margin-top: 10px; font-size: 0.9rem; color: #666;">
                Showing first 5,000 samples.
            </div>
        </div>
    }
</div>
@page "/"
@inject NavigationManager Nav
@inject FridgeService Fridge
@implements IAsyncDisposable

<nav class="navbar">
    <div class="container py-3 position-relative">
        <div class="title">
            X-Cooling <span class="brand-blue">Blue</span>
        </div>
    </div>
</nav>

<div class="container py-4 d-flex flex-column align-items-center">

    <div class="pulse-wrap my-4">
        <div class="ring ring-1"></div>
        <div class="ring ring-2"></div>
        <div class="core">
            <i class="bi bi-thermometer-half core-icon @(connected ? "icon-ok" : "")"></i>
        </div>
    </div>

    <div class="card card-clean w-100 mb-4">
        <div class="card-body text-center p-4">

            <div class="text-secondary mb-2 label-upper">
                @(connected ? "Connected" : "Connecting")
            </div>

            <div class="status-label mb-3">@statusText</div>

            <div class="progress mb-3" style="height:4px;border-radius:2px;">
                <div class="progress-bar @(connected ? "" : "progress-bar-animated")"
                     role="progressbar"
                     style="width:@(progress)%;transition:width .4s ease;">
                </div>
            </div>

            <div class="text-secondary label-sub">@subText</div>
        </div>
    </div>

    <div class="card card-clean w-100">
        <div class="card-body">
            <div class="status-item d-flex justify-content-between">
                <span class="text-secondary">Status</span>
                @if (connected)
                {
                    <span class="badge bg-success">Online</span>
                }
                else if (failed)
                {
                    <span class="badge bg-danger">Unreachable</span>
                }
                else
                {
                    <span class="badge bg-secondary">Waiting</span>
                }
            </div>
        </div>
    </div>

</div>

@code {
    private string statusText = "Reaching device…";
    private string subText    = "Connecting to X-Cooling service";
    private int    progress   = 0;
    private bool   connected  = false;
    private bool   failed     = false;

    private CancellationTokenSource _cts = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RunSequence(_cts.Token);
    }

    private async Task RunSequence(CancellationToken ct)
    {
        await AnimateProgress(0, 30, 600, ct);
        SetStatus("Handshaking…", "Awaiting device response");

        bool ok = await TryConnect();

        if (!ok)
        {
            failed = true;
            SetStatus("Retrying…", "Device may be waking up");
            await AnimateProgress(progress, 55, 500, ct);
            failed = false;
            ok = await TryConnect();
        }

        if (ok)
        {
            connected = true;
            SetStatus("Online", "Redirecting to dashboard…");
            await AnimateProgress(progress, 100, 500, ct);
            StateHasChanged();
            await Task.Delay(600, ct);
            Nav.NavigateTo("/home");
        }
        else
        {
            failed = true;
            SetStatus("Timed out", "Could not reach device");
            await AnimateProgress(progress, 100, 800, ct);
            StateHasChanged();
        }
    }

    private async Task<bool> TryConnect()
    {
        var ok = await Fridge.GetStatus();
        await AnimateProgress(progress, 85, 400, _cts.Token);
        return ok;
    }

    private async Task AnimateProgress(int from, int to, int durationMs, CancellationToken ct)
    {
        int steps = Math.Abs(to - from);
        if (steps == 0) return;
        int delay = Math.Max(durationMs / steps, 4);
        for (int i = from; i <= to; i++)
        {
            if (ct.IsCancellationRequested) return;
            progress = i;
            StateHasChanged();
            await Task.Delay(delay, ct);
        }
    }

    private void SetStatus(string main, string sub)
    {
        statusText = main;
        subText    = sub;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
@page "/maintenance"

<nav class="navbar">
    <div class="container py-3 position-relative">
        <div class="title">
            X-Cooling <span class="brand-blue">Blue</span> <span style="font-weight: normal;"><i>Maintenance</i></span>
        </div>
    </div>
</nav>

<div class="container py-4">
    <!-- WIFI SETTINGS -->
    <div class="card card-clean mb-4">
        <div class="card-body">
            <h5 class="mb-3">WiFi Settings</h5>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span>SSID</span>
                <button class="btn btn-outline-primary btn-sm param-btn">
                    <span>XCooling</span>
                </button>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <span>Password</span>
                <button class="btn btn-outline-primary btn-sm param-btn" style="text-align: right;">
                    <span>****</span>
                </button>
            </div>
        </div>
    </div>

    <!-- DEFROST SETTINGS -->
    <div class="card card-clean mb-4">
        <div class="card-body">
            <h5 class="mb-3">Defrost Settings</h5>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span>Defrost Timeout (min)</span>
                <button class="btn btn-outline-primary btn-sm param-btn">
                    <span>30</span>
                </button>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span>Defrost Interval (h)</span>
                <button class="btn btn-outline-primary btn-sm param-btn">
                    <span>12</span>
                </button>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <span>Compressor During Defrost</span>
                <button class="btn btn-outline-primary btn-sm param-btn">
                    <span>Off</span>
                </button>
            </div>
        </div>
    </div>

    <!-- TEMPERATURE LIMITS -->
    <div class="card card-clean mb-4">
        <div class="card-body">
            <h5 class="mb-3">Temperature Limits</h5>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span>Min Temperature (°C)</span>
                <button class="btn btn-outline-primary btn-sm param-btn">
                    <span>0</span>
                </button>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <span>Max Temperature (°C)</span>
                <button class="btn btn-outline-primary btn-sm param-btn">
                    <span>8</span>
                </button>
            </div>
        </div>
    </div>

    <!-- COMPRESSOR SETTINGS -->
    <div class="card card-clean mb-4">
        <div class="card-body">
            <h5 class="mb-3">Compressor</h5>

            <div class="d-flex justify-content-between align-items-center">
                <span>Compressor Delay (s)</span>
                <button class="btn btn-outline-primary btn-sm param-btn">
                    <span>30</span>
                </button>
            </div>
        </div>
    </div>
</div>
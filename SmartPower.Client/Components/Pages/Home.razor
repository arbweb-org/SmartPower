
@page "/Home"
@inject FridgeService Fridge
@implements IAsyncDisposable

<nav class="navbar">
    <div class="container py-3 position-relative">
        <div class="title">
            X-Cooling <span class="brand-blue">Blue</span>
        </div>

        <div class="top-icons">
            <a class="icon-btn" href="/maintenance"><i class="bi bi-gear"></i></a>
        </div>
    </div>
</nav>

<div class="container py-4">
    <!-- TEMPERATURE -->
    <div class="card card-clean mb-4">
        <div class="card-body text-center p-4">
            <div class="text-secondary mb-2">Cabinet Temperature</div>

            <div class="temp">@(temperature.HasValue ? FormatTemp(temperature.Value) : "—")</div>

            <div class="text-secondary">Celsius</div>
        </div>
    </div>

    <!-- STATUS -->
    <div class="card card-clean mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between py-2 border-bottom">
                <span>Compressor</span>
                <span class="badge bg-success">Running</span>
            </div>

            <div class="d-flex justify-content-between py-2 border-bottom">
                <span>Door</span>
                <span class="badge bg-success">Closed</span>
            </div>

            <div class="d-flex justify-content-between py-2">
                <span>Defrost</span>
                <span class="badge bg-secondary">Idle</span>
            </div>
        </div>
    </div>

    <!-- SET TEMPERATURE -->
    <div class="card card-clean mb-4">
        <div class="card-body text-center p-4">

            <h5 class="mb-4">Set Temperature</h5>

            <div class="d-flex justify-content-center align-items-center gap-3">

                <button class="btn btn-light border control-btn" @onclick="DecrementTarget">
                    <i class="bi bi-dash-lg"></i>
                </button>

                <div class="display-6 fw-bold" id="setTemp">@targetTemp°C</div>

                <button class="btn btn-light border control-btn" @onclick="IncrementTarget">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>

            <small class="text-secondary d-block mt-3">
                Operator control (safe adjustment)
            </small>
        </div>
    </div>
</div>

@code {
    private double? temperature;
    private int targetTemp = 5;
    private Timer? _pollTimer;
    private Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        var paramsStr = await Fridge.GetParameters();
        if (paramsStr != null)
        {
            var parts = paramsStr.Split('|');
            if (parts.Length > 0 && int.TryParse(parts[0], out var t))
                targetTemp = t;
        }

        _pollTimer = new Timer(async _ =>
        {
            temperature = await Fridge.GetTemperature1();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void IncrementTarget()
    {
        targetTemp++;
        ScheduleSetTemp();
    }

    private void DecrementTarget()
    {
        targetTemp--;
        ScheduleSetTemp();
    }

    private void ScheduleSetTemp()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(async _ =>
        {
            await Fridge.SetTargetTemp(targetTemp);
        }, null, TimeSpan.FromSeconds(2), Timeout.InfiniteTimeSpan);
    }

    private string FormatTemp(double val)
    {
        string sign = val < 0 ? "-" : "\u00a0";
        return $"{sign}{Math.Abs(val):F1}°";
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollTimer is not null)
            await _pollTimer.DisposeAsync();
        if (_debounceTimer is not null)
            await _debounceTimer.DisposeAsync();
    }
}